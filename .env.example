# =============================================================================
# Environment Variables - Geburtstagspilot
# =============================================================================
# Local development:
#   cp .env.example .env.local  (then fill in real values)
#   NEVER commit .env.local to version control!
#
# Vercel deployment (REQUIRED - without these the app shows login errors):
#   1. Go to Vercel Dashboard > Your Project > Settings > Environment Variables
#   2. Add ALL variables below that apply to you (Production + Preview + Development)
#   3. NEXT_PUBLIC_* vars are baked into the client bundle at BUILD TIME -
#      they MUST be set in Vercel before deploying, or auth will not work
#   4. After adding vars, trigger a new deployment via GitHub Actions
#
# Supabase Auth configuration (also required in Supabase dashboard):
#   - Authentication > URL Configuration > Site URL: https://www.geburtstagspilot.de
#   - Authentication > URL Configuration > Redirect URLs:
#       https://www.geburtstagspilot.de/**
#       http://localhost:3000/**
# =============================================================================

# --- Next.js -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Geburtstagspilot

# --- Supabase ----------------------------------------------------------------
# Local development (Docker): http://127.0.0.1:55001
# Hosted Supabase:            https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# The Supabase schema used by the application.
# Use "public" (default) or a custom schema name (e.g. "app", "live").
# Must match the schema exposed in Supabase > Project Settings > API > Exposed schemas.
# Also used by the GitHub deploy workflow (db_schema input) if you need to override Vercel's env.
SUPABASE_DB_SCHEMA=public
# Browser-accessible schema name (must match SUPABASE_DB_SCHEMA)
NEXT_PUBLIC_SUPABASE_DB_SCHEMA=public

# --- Optional: Additional Services ------------------------------------------
# NEXT_PUBLIC_GA_TRACKING_ID=
# RESEND_API_KEY=
